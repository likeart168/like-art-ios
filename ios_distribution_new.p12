    <!-- 自愈：JS加载失败自动刷新 -->
    <script>
      (function(){
        if (sessionStorage.getItem('_lr')) return;
        window.addEventListener('error',function(e){
          if (e.target&&e.target.tagName==='SCRIPT'&&!sessionStorage.getItem('_lr')){
            sessionStorage.setItem('_lr','1');
            location.reload(true);
          }
        },true);
      })();
    </script>
